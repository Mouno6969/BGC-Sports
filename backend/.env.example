# ---------------------------------------------------------------------------
# BGC Sports — Backend environment variables
# Copy this file to ".env" and fill in real values.
# ---------------------------------------------------------------------------

# Port the Express/Socket.IO server listens on
PORT=4000

# Comma-separated list of allowed front-end origins for CORS.
# Example for local dev + Vercel deployment:
#   http://localhost:5173,https://your-app.vercel.app
CLIENT_ORIGIN=http://localhost:5173

# ----------------------------- Admin panel ---------------------------------
# Password required to access the admin panel (set/update the stream URL).
# CHANGE THIS to a strong secret in production.
ADMIN_PASSWORD=changeme-admin-password

# ----------------------------- Live stream ---------------------------------
# Default stream URL served to clients before an admin updates it.
# Can be an HLS (.m3u8) URL, a YouTube URL, or a Twitch channel URL.
DEFAULT_STREAM_URL=https://test-streams.mux.dev/x36xhzz/x36xhzz.m3u8

# Stream type: "hls" | "youtube" | "twitch"
DEFAULT_STREAM_TYPE=hls

# ----------------------------- LiveKit (SFU) -------------------------------
# Get these from LiveKit Cloud (https://cloud.livekit.io) free tier,
# or from your self-hosted LiveKit server config.
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
# Public WebSocket URL of your LiveKit server, e.g.:
#   wss://your-project.livekit.cloud
LIVEKIT_URL=wss://your-project.livekit.cloud

# Maximum participants allowed per watch-party room (MVP cap = 8)
MAX_PARTICIPANTS_PER_ROOM=8

# ----------------------------- BGC AI Agent --------------------------------
# AI providers for the @bgc World Cup analysis agent.
# Configure at least ONE provider. The system tries them in order and falls
# back to the next if one fails. Priority order is configurable below.
#
# Provider priority (comma-separated). Default order if not set:
#   groq,openrouter,mistral,cerebras,gemini,nvidia_deepseek,nvidia_llama,huggingface
AI_PROVIDER_ORDER=groq,openrouter,mistral,cerebras

# Groq — Fast inference (recommended first choice)
# Get key at: https://console.groq.com/keys
GROQ_API_KEY=

# Cerebras — Ultra-fast inference
# Get key at: https://cloud.cerebras.ai/
CEREBRAS_API_KEY=

# Google Gemini — Large context, multimodal
# Get key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# NVIDIA NIM — DeepSeek, Llama models
# Get key at: https://build.nvidia.com/
NVIDIA_DEEPSEEK_API_KEY=
NVIDIA_LLAMA_API_KEY=

# OpenRouter — Access to many models
# Get key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Mistral AI
# Get key at: https://console.mistral.ai/api-keys
MISTRAL_API_KEY=

# HuggingFace Inference API
# Get key at: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=

# ----------------------------- Live Web Search -----------------------------
# Used by BGC AI to fetch CURRENT information before answering (prevents
# backdated/hallucinated scores & news). Providers run in parallel and merge.
# Configure at least one. All three is best.

# Serper.dev — Google Search API
# Get key at: https://serper.dev/
SERPER_API_KEY=

# Tavily — AI-optimized web search
# Get key at: https://tavily.com/
TAVILY_API_KEY=

# SearchSpace — fast/cheap neural web search
# Get key at: https://www.searchspace.io/
SEARCHSPACE_API_KEY=

# ----------------------------- Free Translator -----------------------------
# Multi-language layer for BGC AI (Bangla / Banglish / etc.):
#   detect → translate to English → chat AI → translate reply back
# Works WITHOUT keys via Google gtx + MyMemory free endpoints.
# Optional keys boost quota / quality (all free, no credit card):

# MyMemory — optional email boosts free daily quota
# Get at: https://mymemory.translated.net/doc/usagelimits.php
MYMEMORY_API_KEY=
# (or set MYMEMORY_EMAIL=you@example.com)

# LibreTranslate — free API key, no card
# Get at: https://portal.libretranslate.com
LIBRETRANSLATE_API_KEY=
# Optional self-hosted / alternate instance:
# LIBRETRANSLATE_URL=https://libretranslate.com

# Reply to Banglish users in romanized Banglish instead of Bangla script:
# BANGLISH_REPLY=1
