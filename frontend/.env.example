# ---------------------------------------------------------------------------
# BGC Sports — Frontend environment variables (Vite).
# Copy to ".env" for local dev. On Vercel, set these in Project Settings.
# All client-exposed vars MUST be prefixed with VITE_.
# ---------------------------------------------------------------------------

# Base URL of the backend (Express + Socket.IO).
# Local dev:   http://localhost:4000
# Production:  https://api.yourdomain.com
VITE_BACKEND_URL=http://localhost:4000

# ----------------------------- Error reporting ------------------------------
# Optional Sentry free-tier DSN (https://sentry.io). When set, JS/API/stream
# errors are also sent to Sentry. Backend intake at /api/errors always works
# without this — check Admin → Client errors or PM2 logs.
# VITE_SENTRY_DSN=https://xxxx@o0.ingest.sentry.io/0
#
# Force reporting in local dev (default: production only):
# VITE_ERROR_REPORTING=1
#
# Optional release label shown in reports:
# VITE_APP_VERSION=1.0.0
